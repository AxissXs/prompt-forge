# ===========================================================================
# PromptForge — Environment Variables Configuration
# Copy this file to .env and fill in your details for deployment on Vercel.
# ===========================================================================

# ───────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION (Build-time)
# ───────────────────────────────────────────────────────────────────────────

# The base URL of your deployed PromptForge API.
# When empty or omitted, PromptForge automatically falls back to a highly-robust
# local adapter (localStorage-backed single-browser demo DB) so the app works
# fully without any backend server.
# For Vercel production: https://your-promptforge-project.vercel.app/api
VITE_API_BASE=

# Google reCAPTCHA v3 (Invisible) Site Key.
# If omitted, PromptForge defaults to Google's official Test Site Key (which always passes)
# allowing you to test registering and logging in immediately without any setups.
# Register keys at: https://www.google.com/recaptcha/admin/create (select v3)
VITE_RECAPTCHA_SITE_KEY=


# ───────────────────────────────────────────────────────────────────────────
# SERVERLESS API CONFIGURATION (Runtime)
# ───────────────────────────────────────────────────────────────────────────

# Your Neon Postgres Connection String.
# Go to https://neon.tech, spin up a free project, and paste the connection string.
# Example: postgres://alex:xxxxxx@ep-cool-butterfly-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Google reCAPTCHA v3 Secret Key.
# Required for server-side verification of reCAPTCHA tokens. Register keys at:
# https://www.google.com/recaptcha/admin/create (select v3)
RECAPTCHA_SECRET_KEY=
